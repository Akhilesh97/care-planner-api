# Care Planner API — environment variables
# Copy this file to .env in the project root and fill in your keys.
# Never commit real API keys.

# ── LLM Provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini           # "openai" | "gemini"

# ── OpenAI (used when LLM_PROVIDER=openai) ───────────────────────────────────
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_MODEL=gpt-4o-mini    # cheapest: gpt-4o-mini | higher quality: gpt-4o

# ── Gemini (used when LLM_PROVIDER=gemini) ───────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite    # confirmed working model on free tier

# ── Unsplash image search — optional ─────────────────────────────────────────
# Without this key, image_url will be null. image_keywords are always returned.
# Free tier: 50 req/hr — register at https://unsplash.com/developers
# UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here
